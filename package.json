{
  "name": "stayhard",
  "private": true,
  "version": "2.5.0",
  "type": "module",
  "description": "Stay Hard — habit tracker SPA",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch --serve",
    "build": "node esbuild.config.mjs",
    "check": "node --check src/main.js",
    "cap:prepare": "bash scripts/cap-prepare.sh",
    "cap:sync": "npm run cap:prepare && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.2",
    "@capacitor/cli": "^7.6.2",
    "@capacitor/core": "^7.6.2",
    "@capacitor/ios": "^7.6.2",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/push-notifications": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6"
  }
}

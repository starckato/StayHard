# Environment / secrets (never commit)
.env
.env.local
.env.production
config.local.js
.stayhard-sb-pat
*.pat
scripts/.env

# Vercel / build output
.vercel
.next

# OS files
.DS_Store
Thumbs.db

# Local-only docs (spec, ops playbook, security backlog, review artifacts, prototypes)
# These contain internal process notes / example user emails / security details
# that should not be in a public repo.
document-private/
document/

# v3-only character assets remaining on disk (production uses GymRat_*)
# Files left from earlier experiments. Safe to delete manually anytime.
assets/Tier[1-6]_*
assets/tier2_*

# Local index.html snapshots (rollback safety nets)
index.html.backup-*

# esbuild bundle output (built fresh by Vercel on every deploy)
dist/

# Capacitor web-dir output (built fresh via npm run cap:prepare)
www/

# Capacitor native platform projects (re-creatable via `npx cap add ios|android`)
ios/
android/

# npm
node_modules/
